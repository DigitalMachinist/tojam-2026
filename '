+    [SerializeField] private bool randomizeOnStart = false;
+
+    private void Start()
+    {
+        if (randomizeOnStart)
+        {
+            transform.Rotate(axis, Random.Range(0f, 360f), Space.Self);
+        }
+    }
+
+    private void Update()
+    {
+        transform.Rotate(axis, degreesPerSecond * Time.deltaTime, Space.Self);
+    }
+}
